# PepTutor root environment example
# Copy this file to `.env` for local development.
# Do not commit real `.env` files or real API keys.

# Optional lesson vector retrieval. The default dev launcher disables vector
# retrieval unless you pass `--full-stack`.
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BINDING_API_KEY=replace-with-your-embedding-api-key
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
PEPTUTOR_LESSON_VECTOR_RETRIEVAL=false
PEPTUTOR_LESSON_QDRANT_LOCATION=:memory:

# Optional Tencent speech credentials. Leave empty unless you use Tencent ASR.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_ASR_SECRET_ID=
TENCENT_ASR_SECRET_KEY=

# Optional DeepSeek key for OpenAI-compatible LLM calls.
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key

# PepTutor classroom speech proxy defaults.
# For local dev, the frontend calls the backend proxy endpoints below; real
# provider credentials stay in local env files and should not be committed.
VITE_PEPTUTOR_TTS_PROVIDER=volcengine
VITE_PEPTUTOR_TTS_API_KEY=replace-with-your-tts-api-key
VITE_DOUBAO_TTS_API_KEY=replace-with-your-tts-api-key
VITE_PEPTUTOR_TTS_APP_ID=replace-with-your-tts-app-id
VITE_DOUBAO_TTS_APP_ID=replace-with-your-tts-app-id
VITE_PEPTUTOR_TTS_CLUSTER=volcano_tts
VITE_PEPTUTOR_TTS_PROXY_URL=/api/peptutor/doubao-tts
VITE_PEPTUTOR_TTS_VOICE=zh_female_vv_uranus_bigtts

VITE_PEPTUTOR_ASR_PROVIDER=volcengine-realtime-transcription
VITE_PEPTUTOR_ASR_APP_ID=replace-with-your-asr-app-id
VITE_DOUBAO_ASR_APP_ID=replace-with-your-asr-app-id
VITE_PEPTUTOR_ASR_API_KEY=replace-with-your-asr-api-key
VITE_DOUBAO_ASR_API_KEY=replace-with-your-asr-api-key
VITE_PEPTUTOR_ASR_MODEL=1.2.1.1
VITE_DOUBAO_ASR_MODEL=1.2.1.1
VITE_PEPTUTOR_ASR_PROXY_URL=/api/peptutor/doubao-realtime-asr
VITE_PEPTUTOR_ASR_RESOURCE_ID=volc.speech.dialog
VITE_PEPTUTOR_ASR_APP_KEY=replace-with-your-asr-app-key
PEPTUTOR_DOUBAO_ASR_SECRET_KEY=replace-with-your-asr-secret-key

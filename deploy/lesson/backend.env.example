HOST=0.0.0.0
PORT=9621

# Production deploys must use hosted APIs for both LLM and embeddings.
PEPTUTOR_REQUIRE_REMOTE_MODELS=1
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=
LLM_MODEL=gpt-4.1-mini
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Core lesson runtime.
PEPTUTOR_LESSON_LIVE_PROMPTS=1
# PEPTUTOR_DEBUG_SIGNALS=1

# Competition baseline: keep vector retrieval off unless you explicitly deploy Qdrant.
PEPTUTOR_LESSON_VECTOR_RETRIEVAL=0
PEPTUTOR_SIMPLEMEM_PROMPT_INJECTION=1
PEPTUTOR_SIMPLEMEM_WRITEBACK=1
PEPTUTOR_SIMPLEMEM_SEMANTIC_RECALL=1
PEPTUTOR_SIMPLEMEM_PROJECT=peptutor-lesson

# Optional hosted vector DB for lesson retrieval enhancement.
# PEPTUTOR_LESSON_QDRANT_URL=
# PEPTUTOR_LESSON_QDRANT_API_KEY=
# PEPTUTOR_LESSON_QDRANT_COLLECTION=peptutor_teaching_blocks

# Optional offline RAGFlow evidence pipeline.
# This is not used by the live lesson runtime unless a future reviewed goal explicitly wires it.
PEPTUTOR_RAGFLOW_ENABLED=0
# RAGFLOW_BASE_URL=http://127.0.0.1:9380
# RAGFLOW_API_KEY=
# RAGFLOW_DATASET_ID=
# RAGFLOW_TIMEOUT_SECONDS=10

# Optional lesson route limiting.
PEPTUTOR_LESSON_RATE_LIMIT_REQUESTS=60
PEPTUTOR_LESSON_RATE_LIMIT_WINDOW_SECONDS=60
PEPTUTOR_SPEECH_TTS_RATE_LIMIT_REQUESTS=20
PEPTUTOR_SPEECH_TTS_RATE_LIMIT_WINDOW_SECONDS=60
PEPTUTOR_SPEECH_ASR_CONNECT_RATE_LIMIT_REQUESTS=6
PEPTUTOR_SPEECH_ASR_CONNECT_RATE_LIMIT_WINDOW_SECONDS=60

# Server-side Doubao credentials. Keep these out of the frontend.
PEPTUTOR_DOUBAO_TTS_APP_ID=
PEPTUTOR_DOUBAO_TTS_API_KEY=
PEPTUTOR_DOUBAO_TTS_CLUSTER=volcano_tts

PEPTUTOR_DOUBAO_ASR_APP_ID=
PEPTUTOR_DOUBAO_ASR_API_KEY=
PEPTUTOR_DOUBAO_ASR_MODEL=1.2.1.1
PEPTUTOR_DOUBAO_ASR_RESOURCE_ID=volc.speech.dialog
PEPTUTOR_DOUBAO_ASR_APP_KEY=PlgvMymc7f3tQnJ6

# Backend auth is optional. Avoid shipping shared frontend credentials publicly.
# AUTH_ACCOUNTS='teacher:replace-me'
# TOKEN_SECRET=replace-me
# LIGHTRAG_API_KEY=replace-me

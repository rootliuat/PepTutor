PEPTUTOR_BACKEND_UPSTREAM=http://peptutor-backend:9621

# Keep lesson and speech traffic same-origin through the frontend nginx proxy.
PEPTUTOR_RUNTIME_LESSON_API_URL=/peptutor-api

# Production lesson mode should prefer backend-native speech proxies.
PEPTUTOR_RUNTIME_TTS_PROVIDER=volcengine
PEPTUTOR_RUNTIME_TTS_MODEL=v1
PEPTUTOR_RUNTIME_TTS_VOICE=zh_female_vv_uranus_bigtts
PEPTUTOR_RUNTIME_TTS_CLUSTER=volcano_tts

PEPTUTOR_RUNTIME_ASR_PROVIDER=volcengine-realtime-transcription
PEPTUTOR_RUNTIME_ASR_MODEL=1.2.1.1
PEPTUTOR_RUNTIME_ASR_RESOURCE_ID=volc.speech.dialog
PEPTUTOR_RUNTIME_ASR_APP_KEY=PlgvMymc7f3tQnJ6

# Keep frontend runtime credentials empty for public deployments.
# If backend auth is required, prefer ingress/network protection instead of
# shipping shared credentials into a public browser bundle.
# PEPTUTOR_RUNTIME_LESSON_API_KEY=
# PEPTUTOR_RUNTIME_LESSON_BEARER_TOKEN=
# PEPTUTOR_RUNTIME_LESSON_ACCESS_TOKEN=
# PEPTUTOR_RUNTIME_LESSON_AUTH_USERNAME=
# PEPTUTOR_RUNTIME_LESSON_AUTH_PASSWORD=

# Optional.
# PEPTUTOR_RUNTIME_ENABLE_KOKORO_FALLBACK=false
# PEPTUTOR_FRONTEND_PORT=8080

# PepTutor LightRAG backend environment example
# Copy this file to `backend/LightRAG/.env` for local development.
# Do not commit real `.env` files or real API keys.

# LLM provider. The current classroom runtime uses the LightRAG backend process,
# so LLM settings belong here.
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_BINDING_API_KEY=replace-with-your-llm-api-key

# Compatibility aliases used by OpenAI-compatible clients.
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=replace-with-your-llm-api-key

# Embedding provider. Used by ingestion/retrieval workflows and by full-stack
# lesson retrieval when vector retrieval is enabled.
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BINDING_API_KEY=replace-with-your-embedding-api-key
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024

# Local demo defaults. `scripts/start_lesson_dev.sh` disables vector retrieval
# unless `--full-stack` is passed.
PEPTUTOR_LESSON_VECTOR_RETRIEVAL=false
PEPTUTOR_LESSON_QDRANT_LOCATION=:memory:

# Optional debug and live-prompt controls.
PEPTUTOR_LESSON_LIVE_PROMPTS=1
PEPTUTOR_DEBUG_SIGNALS=1

# Optional offline evidence pipeline. This is not connected to live classroom
# routing by default.
PEPTUTOR_RAGFLOW_ENABLED=0
RAGFLOW_BASE_URL=http://127.0.0.1:9380
RAGFLOW_API_KEY=
RAGFLOW_DATASET_ID=
RAGFLOW_TIMEOUT_SECONDS=10

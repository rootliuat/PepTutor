    },
    {
      "id": "n1000001",
      "type": "text",
      "x": 80,
      "y": -20,
      "width": 260,
      "height": 80,
      "text": "用户说话或输入文字",
      "color": "5"
    },
    {
      "id": "n1000002",
      "type": "text",
      "x": 80,
      "y": 180,
      "width": 320,
      "height": 100,
      "text": "接收语音或文本\n做输入标准化",
      "color": "4"
    },
    {
      "id": "n1000003",
      "type": "text",
      "x": 80,
      "y": 420,
      "width": 300,
      "height": 110,
      "text": "读取 LessonState\n确定当前页、当前 block、是否在等回答",
      "color": "4"
    },
    {
      "id": "n1000004",
      "type": "text",
      "x": 460,
      "y": 420,
      "width": 300,
      "height": 120,
      "text": "Turn Router 分类回合\nanswer_question / ask_knowledge /\nask_help / navigation / social / meta_learning",
      "color": "4"
    },
    {
      "id": "n1000005",
      "type": "text",
      "x": 860,
      "y": 420,
      "width": 300,
      "height": 120,
      "text": "如果当前在等学生作答\n优先进入本地判定链路\n默认不做全局检索",
      "color": "2"
    },
    {
      "id": "n1000006",
      "type": "text",
      "x": 200,
      "y": 730,
      "width": 320,
      "height": 120,
      "text": "本地优先判定\ncurrent block -> page -> unit\n给出 correct / acceptable / incorrect",
      "color": "2"
    },
    {
      "id": "n1000007",
      "type": "text",
      "x": 620,
      "y": 730,
      "width": 300,
      "height": 120,
      "text": "教学动作选择\nconfirm / hint / correct /\nfollow_up / review_prerequisite",
      "color": "2"
    },
    {
      "id": "n1000008",
      "type": "text",
      "x": 1040,
      "y": 730,
      "width": 300,
      "height": 120,
      "text": "如果是 ask_help\n优先降阶讲解\n而不是直接抛标准答案",
      "color": "2"
    },
    {
      "id": "n1000009",
      "type": "text",
      "x": 1460,
      "y": 730,
      "width": 300,
      "height": 120,
      "text": "如果是 navigation 或 social\n只做状态切换或简短社交回复",
      "color": "2"
    },
    {
      "id": "n1000010",
      "type": "text",
      "x": 200,
      "y": 1020,
      "width": 300,
      "height": 110,
      "text": "LightRAG\n范围受控检索\nblock -> page -> unit -> global",
      "color": "5"
    },
    {
      "id": "n1000011",
      "type": "text",
      "x": 620,
      "y": 1020,
      "width": 300,
      "height": 110,
      "text": "SimpleMem\n读取或写回学生长期记忆\nTeachingUnit / LearningCrystal",
      "color": "6"
    },
    {
      "id": "n1000012",
      "type": "text",
      "x": 1040,
      "y": 1020,
      "width": 300,
      "height": 110,
      "text": "模型层\n生成老师回复草案\n附带动作与语气标签",
      "color": "3"
    },
    {
      "id": "n1000013",
      "type": "text",
      "x": 1460,
      "y": 1020,
      "width": 320,
      "height": 110,
      "text": "AIRI 输出\n文字 / TTS / Live2D 表情动作",
      "color": "4"
    },
    {
      "id": "n1000014",
      "type": "text",
      "x": 1900,
      "y": 1020,
      "width": 300,
      "height": 110,
      "text": "用户看到结果\n进入下一轮课堂互动",
      "color": "5"
    },
    {
      "id": "n1000015",
      "type": "text",
      "x": 1880,
      "y": 420,
      "width": 340,
      "height": 140,
      "text": "知识问答单独链路\nask_knowledge 可直接触发\n范围受控教材检索",
      "color": "5"
    },
    {
      "id": "n1000016",
      "type": "text",
      "x": 1880,
      "y": 730,
      "width": 340,
      "height": 140,
      "text": "元学习链路\nmeta_learning 读取学生记忆\n总结强项、弱项、下一步建议",
      "color": "6"
    },
    {
